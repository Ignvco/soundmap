{
  "expo": {
    "name":              "SoundMap",
    "slug":              "soundmap",
    "version":           "2.0.0",
    "orientation":       "portrait",
    "icon":              "./assets/soundmap-logo.png",
    "scheme":            "soundmap",
    "userInterfaceStyle":"dark",
    "newArchEnabled":    true,
    "splash": {
      "image":           "./assets/soundmap-logo.png",
      "resizeMode":      "contain",
      "backgroundColor": "#06060a"
    },
    "ios": {
      "supportsTablet":   false,
      "bundleIdentifier": "com.levelpro.soundmap"
    },
    "android": {
      "package":         "com.levelpro.soundmap",
      "adaptiveIcon": {
        "foregroundImage": "./assets/soundmap-logo.png",
        "backgroundColor": "#06060a"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output":  "static"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": { "projectId": "TU_EAS_PROJECT_ID" }
    }
  }
}
